{
  "name": "gpu-coop",
  "version": "0.1.0",
  "description": "Share GPUs with friends",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:ts && npm run copy:proto && concurrently \"npm run dev:vite\" \"npm run dev:electron\" \"npm run dev:ts-watch\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron . $ELECTRON_EXTRA_ARGS",
    "dev:ts-watch": "concurrently \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"tsc -p tsconfig.daemon.json --watch --preserveWatchOutput\"",
    "build": "npm run build:vite && npm run build:ts && npm run copy:proto",
    "build:vite": "vite build",
    "build:ts": "tsc -p tsconfig.main.json && tsc -p tsconfig.daemon.json",
    "copy:proto": "node -e \"const fs=require('fs'),path=require('path');fs.mkdirSync('dist/proto',{recursive:true});fs.copyFileSync('src/proto/coop.proto','dist/proto/coop.proto');console.log('[build] copied coop.proto to dist/proto/')\"",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.11.1",
    "@grpc/proto-loader": "^0.7.13",
    "better-sqlite3": "^11.3.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.3",
    "uuid": "^10.0.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
